---
import Layout from '../../layouts/Layout.astro';
import BlogDetail from '../../components/BlogDetail.jsx';
import { blogsData } from '../../data/blogsData.js';

export function getStaticPaths() {
  return blogsData.map((blog) => ({
    params: { slug: blog.slug },
  }));
}

const { slug } = Astro.params;

// Calculate props for the component
const blogIndex = blogsData.findIndex((b) => b.slug === slug);
const blog = blogsData[blogIndex];

const prevBlog = blogIndex > 0 ? blogsData[blogIndex - 1] : null;
const nextBlog = blogIndex < blogsData.length - 1 ? blogsData[blogIndex + 1] : null;

const relatedBlogs = blogsData
  .filter((b) => b.slug !== slug)
  .map((b) => {
    let score = 0;
    if (b.category === blog.category) score += 3;
    const commonTags = b.tags.filter(t => blog.tags.includes(t));
    score += commonTags.length;
    return { blog: b, score };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 2)
  .map(item => item.blog);
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": blog.title,
  "description": blog.metaDescription || blog.excerpt,
  "image": blog.banner ? `https://craftdesignstudio.in${blog.banner}` : "https://craftdesignstudio.in/banner.jpg",
  "datePublished": blog.date,
  "author": {
    "@type": "Person",
    "name": blog.author || "Vishvarajsinh Zala"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Craft Design Studio",
    "logo": {
      "@type": "ImageObject",
      "url": "https://craftdesignstudio.in/Logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://craftdesignstudio.in/blog/${blog.slug}`
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://craftdesignstudio.in"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Insights",
      "item": "https://craftdesignstudio.in/blog"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": blog.title,
      "item": `https://craftdesignstudio.in/blog/${blog.slug}`
    }
  ]
};
---

<Layout 
	title={`${blog.metaTitle || blog.title} | Craft Design Studio`}
	description={blog.metaDescription}
	image={blog.banner}
>
	<script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
	<script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
	<BlogDetail 
		client:load 
		blog={blog} 
		prevBlog={prevBlog} 
		nextBlog={nextBlog} 
		relatedBlogs={relatedBlogs} 
	/>
</Layout>
